# Shared
NODE_ENV=development

# Infra ports
POSTGRES_PORT=5432
REDIS_PORT=6379
MEILI_PORT=7700
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# App ports
WEB_PORT=5173
API_GATEWAY_PORT=4000
IDENTITY_SERVICE_PORT=4001
TENANT_SERVICE_PORT=4002
VENDOR_SERVICE_PORT=4003
CATALOG_SERVICE_PORT=4004
